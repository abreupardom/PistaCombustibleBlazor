@page "/vehiculos"
@rendermode InteractiveServer
@using PistaCombustible.Models
@using PistaCombustible.Services
@using DevExpress.Blazor
@inject VehiculoService VehiculoService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Gestión de vehículos</PageTitle>


<div style="width: 80%; margin: auto;">
    <div class="d-flex align-items-center mb-3">
        <h1 class="me-3 mb-0">Lista de vehículos</h1>
        <DxButton RenderStyle="ButtonRenderStyle.Primary" Size="ButtonSize.Small" Click="() => AdicionarVehiculo()"
                  IconCssClass="bi bi-plus-circle" />
            
    </div>
   
    @if (VehiculoLista == null)
    {
        <span>Cargando...</span>
    }
    else if (!VehiculoLista.Any())
    {
        <div class="alert alert-warning">
            No hay vehículos registrados.
        </div>
    }
    else
    {
        <DxGrid Data="VehiculoLista" ShowFilterRow="true" AllowSort="true" AllowPaging="true" PageSize="10"
                ShowPageSizeSelector="true" PageSizes="new int[] { 5, 10, 20, 50 }" AllowGroup="true" CssClass="shadow-sm"
                ColumnCaptionAlignment="GridTextAlignment.Center" ShowSearchBox="true">
        
            <Columns>
                <DxGridDataColumn FieldName="Id" Caption="ID" SortOrder="GridColumnSortOrder.Ascending" />
            
                <DxGridDataColumn FieldName="Marca" Caption="Marca" />
            
                <DxGridDataColumn FieldName="Modelo" Caption="Modelo" />

                <DxGridDataColumn FieldName="Matricula" Caption="Matricula" />

                <DxGridDataColumn FieldName="Nombre" Caption="Chofer" />
            
                <DxGridDataColumn FieldName="Activo" Caption="Estado">
                    <CellDisplayTemplate>
                        @if ((bool)context.Value)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="TipoCombustible" Caption="Tipo combustible" />

                <DxGridDataColumn FieldName="FechaCreacion" Caption="Fecha creación" />
            
                <DxGridDataColumn Caption="Acciones" Width="120px">
                    <CellDisplayTemplate>
                        @{
                            var Vehiculos = (Vehiculo)context.DataItem;
                            <DxButton RenderStyle="ButtonRenderStyle.Danger" Size="ButtonSize.Small"
                                      Click="() => EliminarVehiculo(Vehiculos.Id)" IconCssClass="bi bi-trash" />
                            <DxButton RenderStyle="ButtonRenderStyle.Primary" Size="ButtonSize.Small"
                                      Click="() => ActualizarVehiculo(Vehiculos.Id)" IconCssClass="bi bi-pen" />
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
        <span class="totalVehiculos d-block mt-3">@VehiculoLista.Count() vehículos en total</span>
    }
</div>

@code {
    private List<Vehiculo> VehiculoLista = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarVehiculos();
    }

    /// <summary>
    /// Carga Vehiculos
    /// </summary>
    /// <returns></returns>
    private async Task CargarVehiculos()
    {
        try
        {
            VehiculoLista = await Task.Run(() => VehiculoService.GetVehiculos());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar Vehiculos: {ex.Message}");
        }
    }

    /// <summary>
    /// Elimina Vehiculos
    /// </summary>
    /// <param name="id"></param>
    /// <returns></returns>
    private async Task EliminarVehiculo(int id)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Está seguro de eliminar este Vehiculos?");

        if (confirmado)
        {
            var success = await Task.Run(() => VehiculoService.DeleteVehiculoFisico(id));
            if (success)
            {
                await CargarVehiculos();
                await JS.InvokeVoidAsync("alert", "Vehiculos eliminado correctamente");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Error al eliminar el Vehiculos");
            }
        }
    }

    /// <summary>
    /// Actualiza vehiculo
    /// </summary>
    /// <param name="id"></param>
    /// <returns></returns>
    private void ActualizarVehiculo(int id)
    {
        Navigation.NavigateTo($"/vehiculoform/{id}");
    }

    /// <summary>
    /// Adiciona Vehiculos
    /// </summary>
    private void AdicionarVehiculo()
    {
        Navigation.NavigateTo($"/vehiculoform");
    }
}