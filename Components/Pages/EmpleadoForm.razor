@page "/empleadoform"
@page "/empleadoform/{Id:int}"
@rendermode InteractiveServer
@using PistaCombustible.Models
@using PistaCombustible.Services
@using DevExpress.Blazor
@inject EmpleadoService EmpleadoService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Gestión de empleados</PageTitle>

<div style="width: 80%;margin: auto;">
    <h1>@(Id == null ? "Crear" : "Editar")  empleado</h1>

    <div class="card p-4 shadow">

        <DxFormLayout 
        CssClass="w-100 demo-form-layout">
            <DxFormLayoutItem 
             Caption="Nombre:">
                <DxTextBox 
                @bind-Text="empleado.Nombre" />
            </DxFormLayoutItem>

            <DxFormLayoutItem 
             Caption="Apellido:">
                <DxTextBox 
                @bind-Text="empleado.Apellido" />
            </DxFormLayoutItem>

            <DxFormLayoutItem 
              Caption="Email:">
                <DxTextBox 
                @bind-Text="empleado.Email" />
            </DxFormLayoutItem>

            <DxFormLayoutItem 
              Caption="Fecha de Nacimiento:">
                <DxDateEdit 
                @bind-Date="empleado.FechaNacimiento" 
                DisplayFormat="dd/MM/yyyy"
                Mask="@DateTimeMask.ShortDate" />
            </DxFormLayoutItem>

            <DxFormLayoutItem 
              Caption="Salario:">
                <DxSpinEdit 
                @bind-Value="empleado.Salario" 
                DisplayFormat="c" 
                MinValue="0" />
            </DxFormLayoutItem>

            <DxFormLayoutItem 
              Caption="Activo:">
                <DxCheckBox 
                @bind-Checked="empleado.Activo" 
                CheckType="CheckType.Switch"
                LabelPosition="LabelPosition.Left" />
            </DxFormLayoutItem>
        </DxFormLayout>

        <div class="w-100 mx-0 mt-3 d-flex gap-2">
            <DxButton 
            RenderStyle="ButtonRenderStyle.Primary" 
            Click="GuardarEmpleado">
                <i class="me-2 bi bi-check-circle"></i> Guardar
            </DxButton>
            @if (Id == null)
            {
                <DxButton 
                RenderStyle="ButtonRenderStyle.Secondary" 
                Click="LimpiarFormulario">
                    <i class="me-2 bi bi-arrow-counterclockwise"></i> Limpiar
                </DxButton>
            }
            <DxButton 
            RenderStyle="ButtonRenderStyle.Danger" 
            Click="Cancelar"><i
                class="me-2 bi bi-x-circle"></i>Cancelar
            </DxButton>
        </div>
    </div>
</div>

@code {

    [Parameter]
    public int? Id { get; set; }
    private Empleado empleado = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpleados();
    }

    /// <summary>
    /// Carga empleados
    /// </summary>
    /// <returns></returns>
    private async Task CargarEmpleados()
    {
        try
        {
            if (Id != null)
            {
                empleado = await Task.Run(() => EmpleadoService.GetEmpleadoById(Id.Value));
            }
            else
            {
                empleado = new Empleado();
                empleado.Activo = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar empleados: {ex.Message}");
        }
    }

    /// <summary>
    /// Guarda o actualiza el empleado
    /// </summary>
    private async Task GuardarEmpleado()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(empleado.Nombre) ||
                string.IsNullOrWhiteSpace(empleado.Apellido) ||
                string.IsNullOrWhiteSpace(empleado.Email) ||
                empleado.FechaNacimiento == null ||
                empleado.Salario == null)
            {
                await JS.InvokeVoidAsync("alert", "Por favor, complete todos los campos requeridos");
                return;
            }

            if (Id != null)
            {
                await Task.Run(() => EmpleadoService.UpdateEmpleado(empleado));
                Navigation.NavigateTo($"/empleados");
            }
            else
            {
                await Task.Run(() => EmpleadoService.AddEmpleado(empleado));
                LimpiarFormulario();
            }
            await JS.InvokeVoidAsync("alert", "Empleado guardado correctamente");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Error al salvar empleados " + ex.Message);
        }
    }

    /// <summary>
    /// Cancela el formulario
    /// </summary>
    private void LimpiarFormulario()
    {
        empleado = new Empleado()
        {
            Activo = true,
            FechaCreacion = DateTime.Now
        };
    }

    /// <summary>
    /// Cancela el formulario
    /// </summary>
    private void Cancelar()
    {
        Navigation.NavigateTo($"/empleados");
    }
}
