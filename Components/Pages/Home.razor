@page "/"
@rendermode InteractiveServer

@using PistaCombustible.Models
@using PistaCombustible.Services
@using DevExpress.Blazor
@inject EmpleadoService EmpleadoService
@inject TanqueService TanqueService
@inject VehiculoService VehiculoService
@inject NavigationManager Navigation

<PageTitle>Detalles y estadísticas</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1>Dashboard de Análisis</h1>
            <hr />
        </div>
    </div>

    @if (EmpleadoLista == null || TanqueLista == null || VehiculoLista == null)
    {
        <div class="alert alert-info">
            Cargando datos...
        </div>
    }
    else if (!EmpleadoLista.Any() && !TanqueLista.Any() && !VehiculoLista.Any())
    {
        <div class="alert alert-warning">
            No hay datos registrados.
        </div>
    }
    else
    {
        <!-- Fila 1: Tarjetas de Empleados -->
       <div class="row">
            <div class="col-md-3 mb-2 border-activo-card">
                <DxFormLayout>
                    <DxFormLayoutGroup 
                        Caption="Empleados Activos" 
                        Decoration="FormLayoutGroupDecoration.Card">
                        <DxFormLayoutItem>
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <i class="bi bi-people-fill text-success" style="font-size: 2.5rem;"></i>
                                <h2 class="text-success display-4 mb-0">@EmpleadoLista.Count(e => e.Activo)</h2>
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>
            </div>

            <div class="col-md-3 mb-2 border-inactivo-card">
                <DxFormLayout>
                    <DxFormLayoutGroup 
                        Caption="Empleados Inactivos" 
                        Decoration="FormLayoutGroupDecoration.Card">
                        <DxFormLayoutItem>
                              <div class="d-flex align-items-center justify-content-center gap-3">
                                <i class="bi bi-people-fill text-danger" style="font-size: 2.5rem;"></i>
                                <h2 class="text-danger display-4 mb-0">@EmpleadoLista.Count(e => !e.Activo)</h2>
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>
            </div>

            <div class="col-md-3 mb-2 border-activo-card">
                <DxFormLayout>
                    <DxFormLayoutGroup 
                        Caption="Vehículos Activos" 
                        Decoration="FormLayoutGroupDecoration.Card">
                        <DxFormLayoutItem>
                              <div class="d-flex align-items-center justify-content-center gap-3">
                                <i class="bi bi-car-front-fill text-success" style="font-size: 2.5rem;"></i>
                                <h2 class="text-success display-4 mb-0">@VehiculoLista.Count(v => v.Activo)</h2>
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>
            </div>

            <div class="col-md-3 mb-2 border-inactivo-card">
                <DxFormLayout>
                    <DxFormLayoutGroup 
                        Caption="Vehículos Inactivos" 
                        Decoration="FormLayoutGroupDecoration.Card">
                        <DxFormLayoutItem>
                              <div class="d-flex align-items-center justify-content-center gap-3">
                                <i class="bi bi-car-front-fill text-danger" style="font-size: 2.5rem;"></i>
                                <h2 class="text-danger display-4 mb-0">@VehiculoLista.Count(v => !v.Activo)</h2>
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>
            </div>
        </div>

        <!-- Fila 2: Gráficos de Tanques (2 columnas) -->
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0">Distribución por tipo de combustible (Tanques)</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosCombustible = TanqueLista
                                .Where(t => t.Activo)
                                .GroupBy(t => t.TipoCombustible ?? "Sin especificar")
                                .Select(g => new TanqueCombustible
                                {
                                    TipoCombustible = g.Key,
                                    Cantidad = g.Count(),
                                    CapacidadTotal = g.Sum(t => t.Capacidad ?? 0)
                                })
                                .ToList();
                        }
                        
                        @if (datosCombustible.Any())
                        {
                            <DxPieChart 
                                Data="@datosCombustible" 
                                Width="100%" 
                                Height="350px" 
                                InnerDiameter="0.5">
                                <DxPieChartSeries 
                                    Name="Combustible"
                                    ArgumentField="@((TanqueCombustible t) => t.TipoCombustible)"
                                    ValueField="@((TanqueCombustible t) => t.CapacidadTotal)">
                                    <DxChartSeriesLabel 
                                        Visible="true" 
                                        Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxPieChartSeries>
                                
                                <DxChartLegend 
                                    Position="RelativePosition.Outside"
                                    HorizontalAlignment="HorizontalAlignment.Center" 
                                    VerticalAlignment="VerticalEdge.Bottom" />
    
                                <DxChartTooltip Enabled="true" >
                                     <div style="padding: 8px;">
                                        <div class="fw-bold">@context.Point.Argument</div>
                                        <div>@($"{context.Point.Value:N0} L")</div>
                                    </div>
                                </DxChartTooltip>
                            </DxPieChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay tanques activos registrados</div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-info text-white">
                        <h4 class="mb-0">Nivel de combustible por tanque</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosNiveles = TanqueLista
                                .Where(t => t.Activo)
                                .Select(t => new TanqueNivel
                                {
                                    Nombre = $"Tanque {t.Id} - {t.TipoCombustible}",
                                    Nivel = t.Nivel ?? 0,
                                    Capacidad = t.Capacidad ?? 0,
                                    EspacioLibre = (t.Capacidad ?? 0) - (t.Nivel ?? 0)
                                })
                                .ToList();
                        }
                        
                        @if (datosNiveles.Any())
                        {
                            <DxChart 
                                Data="@datosNiveles" 
                                Width="100%" 
                                Height="350px">
                                <DxChartStackedBarSeries 
                                    Name="Nivel Actual" 
                                    ArgumentField="@((TanqueNivel t) => t.Nombre)"
                                    ValueField="@((TanqueNivel t) => t.Nivel)" 
                                    Color="System.Drawing.Color.Orange">
                                    <DxChartSeriesLabel 
                                        Visible="true" 
                                        Position="RelativePosition.Inside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartStackedBarSeries>
                                
                                <DxChartStackedBarSeries 
                                    Name="Espacio Libre" 
                                    ArgumentField="@((TanqueNivel t) => t.Nombre)"
                                    ValueField="@((TanqueNivel t) => t.EspacioLibre)" 
                                    Color="System.Drawing.Color.LightGray">
                                    <DxChartSeriesLabel 
                                        Visible="true" 
                                        Position="RelativePosition.Inside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartStackedBarSeries>

                                <DxChartStackedBarSeries 
                                    Name="Capacidad" 
                                    ArgumentField="@((TanqueNivel t) => t.Nombre)"
                                    ValueField="@((TanqueNivel t) => t.Capacidad)" 
                                    Color="System.Drawing.Color.Green">
                                    <DxChartSeriesLabel 
                                        Visible="true" 
                                        Position="RelativePosition.Inside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartStackedBarSeries>
                                
                                <DxChartLegend 
                                    Position="RelativePosition.Outside"
                                    HorizontalAlignment="HorizontalAlignment.Center" 
                                    VerticalAlignment="VerticalEdge.Bottom" />

                                <DxChartTooltip Enabled="true" >
                                    <div style="padding: 8px;">
                                        <div class="fw-bold">@context.Point.Argument</div>
                                        <div>
                                            @{
                                                switch (context.Point.SeriesName)
                                                {
                                                    case "Nivel Actual":
                                                        <div>Nivel Actual: @($"{context.Point.Value:N0} L")</div>;
                                                        break;
                                                    case "Espacio Libre":
                                                        <div>Espacio Libre: @($"{context.Point.Value:N0} L")</div>;
                                                        break;
                                                    case "Capacidad":
                                                        <div>Capacidad: @($"{context.Point.Value:N0} L")</div>;
                                                        break;
                                                }
                                            }
                                        </div>
                                    </div>
                                </DxChartTooltip>
                            </DxChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay tanques activos registrados</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 3: Gráficos de Vehículos (2 columnas) -->
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">Vehículos por tipo de combustible</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosVehiculosCombustible = VehiculoLista
                                .Where(v => v.Activo)
                                .GroupBy(v => v.TipoCombustible ?? "Sin especificar")
                                .Select(g => new VehiculoCombustible
                                {
                                    TipoCombustible = g.Key,
                                    Cantidad = g.Count()
                                })
                                .ToList();
                        }
                        
                        @if (datosVehiculosCombustible.Any())
                        {
                            <DxPieChart 
                                Data="@datosVehiculosCombustible" 
                                Width="100%" 
                                Height="350px">
                                <DxPieChartSeries 
                                    Name="Vehículos por Combustible"
                                    ArgumentField="@((VehiculoCombustible v) => v.TipoCombustible)"
                                    ValueField="@((VehiculoCombustible v) => v.Cantidad)">
                                    <DxChartSeriesLabel 
                                        Visible="true" 
                                        Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxPieChartSeries>

                                <DxChartLegend 
                                    Position="RelativePosition.Outside"
                                    HorizontalAlignment="HorizontalAlignment.Center" 
                                    VerticalAlignment="VerticalEdge.Bottom" />
    
                                <DxChartTooltip Enabled="true">
                                    <div style="padding: 8px;">
                                        <div class="fw-bold">@context.Point.Argument</div>
                                        <div>Vehículos: @($"{context.Point.Value:N0}")</div>
                                    </div>
                                </DxChartTooltip>
                            </DxPieChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay vehículos activos registrados</div>
                        }
                    </div>
                </div>
            </div>

             <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white">
                        <h4 class="mb-0">Vehículos por marca</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosMarcas = VehiculoLista
                                .Where(v => v.Activo && !string.IsNullOrEmpty(v.Marca))
                                .GroupBy(v => v.Marca)
                                .Select(g => new VehiculoMarca
                                {
                                    Marca = g.Key,
                                    Cantidad = g.Count()
                                })
                                .OrderByDescending(m => m.Cantidad)
                                .Take(5)
                                .ToList();
                        }
                        
                        @if (datosMarcas.Any())
                        {
                            <DxChart 
                                Data="@datosMarcas" 
                                Width="100%" 
                                Height="350px">
                                <DxChartTitle Text="Marcas de vehículos">
                                    <DxChartSubTitle Text="Cantidad de vehículos por marca" />
                                </DxChartTitle>
                                <DxChartAreaSeries       
                                    Name="Cantidad por Marca" 
                                    ArgumentField="@((VehiculoMarca m) => m.Marca)"
                                    ValueField="@((VehiculoMarca m) => m.Cantidad)" 
                                    Color="System.Drawing.Color.Purple">
                                    <DxChartSeriesLabel 
                                        Visible="true" 
                                        Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartAreaSeries>
                                
                                <DxChartLegend 
                                    Position="RelativePosition.Outside"
                                    HorizontalAlignment="HorizontalAlignment.Center" 
                                    VerticalAlignment="VerticalEdge.Bottom" />
  
                                <DxChartTooltip Enabled="true">
                                     <div style="padding: 8px;">
                                        <div class="fw-bold">@context.Point.Argument</div>
                                        <div>Vehículos: @($"{context.Point.Value:N0} ")</div>
                                    </div>
                                </DxChartTooltip>
                            </DxChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay datos de marcas disponibles</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 4: Marcas de Vehículos (2 columnas) -->
        <div class="row">
           

            
        </div>

        <!-- Fila 5: Lista de Vehículos -->
        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">Lista detallada de vehículos</h4>
                            <DxButton 
                                RenderStyle="ButtonRenderStyle.Light"
                                Size="ButtonSize.Small" 
                                IconCssClass="bi bi-plus-circle"
                                Click="() => AdicionarVehiculo()" />
                        </div>
                    </div>
                    <div class="card-body">
                        <VehiculosLista 
                            verTitulo="false" 
                            verExportar="false" 
                            verAcciones="false" 
                            verTotal="false"/>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 6: Resumen de Tanques -->
        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">Lista detallada de tanques</h4>
                            <DxButton 
                                RenderStyle="ButtonRenderStyle.Light"
                                Size="ButtonSize.Small" 
                                IconCssClass="bi bi-plus-circle"
                                Click="() => AdicionarTanque()" />
                        </div>
                    </div>
                    <div class="card-body">
                        <TanquesLista
                            verTitulo="false"
                            verExportar="false" 
                            verAcciones="false" 
                            verTotal="false"/>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Empleado> EmpleadoLista = new();
    private List<Tanque> TanqueLista = new();
    private List<Vehiculo> VehiculoLista = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpleados();
        await CargarTanques();
        await CargarVehiculos();
    }

    private async Task CargarEmpleados()
    {
        try
        {
            EmpleadoLista = await Task.Run(() => EmpleadoService.GetEmpleados());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar empleados: {ex.Message}");
        }
    }

    private async Task CargarTanques()
    {
        try
        {
            TanqueLista = await Task.Run(() => TanqueService.GetTanques());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar tanques: {ex.Message}");
        }
    }

    private async Task CargarVehiculos()
    {
        try
        {
            VehiculoLista = await Task.Run(() => VehiculoService.GetVehiculos());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar vehículos: {ex.Message}");
        }
    }

    /// <summary>
    /// Adiciona Tanques
    /// </summary>
    private void AdicionarTanque()
    {
        Navigation.NavigateTo($"/tanqueform");
    }

    /// <summary>
    /// Adiciona Vehiculos
    /// </summary>
    private void AdicionarVehiculo()
    {
        Navigation.NavigateTo($"/vehiculoform");
    }

    // Clases auxiliares
    public class EmpleadoEstado
    {
        public string? Estado { get; set; }
        public int Cantidad { get; set; }
    }

    public class TanqueCombustible
    {
        public string? TipoCombustible { get; set; }
        public int Cantidad { get; set; }
        public decimal CapacidadTotal { get; set; }
    }

    public class TanqueNivel
    {
        public string? Nombre { get; set; }
        public decimal Nivel { get; set; }
        public decimal Capacidad { get; set; }
        public decimal EspacioLibre { get; set; }
    }

    public class VehiculoEstado
    {
        public string? Estado { get; set; }
        public int Cantidad { get; set; }
    }

    public class VehiculoCombustible
    {
        public string? TipoCombustible { get; set; }
        public int Cantidad { get; set; }
    }

    public class VehiculoMarca
    {
        public string? Marca { get; set; }
        public int Cantidad { get; set; }
    }
}