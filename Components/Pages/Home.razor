@page "/"

@using PistaCombustible.Models
@using PistaCombustible.Services
@using DevExpress.Blazor
@inject EmpleadoService EmpleadoService
@inject TanqueService TanqueService
@inject VehiculoService VehiculoService

<PageTitle>Dashboard de Análisis</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1>Dashboard de Análisis</h1>
            <hr />
        </div>
    </div>

    @if (EmpleadoLista == null || TanqueLista == null || VehiculoLista == null)
    {
        <div class="alert alert-info">
            Cargando datos...
        </div>
    }
    else if (!EmpleadoLista.Any() && !TanqueLista.Any() && !VehiculoLista.Any())
    {
        <div class="alert alert-warning">
            No hay datos registrados.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Distribución de Empleados</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosEmpleados = new List<EmpleadoEstado>
                            {
                                new EmpleadoEstado { Estado = "Activos", Cantidad = EmpleadoLista.Count(e => e.Activo) },
                                new EmpleadoEstado { Estado = "Inactivos", Cantidad = EmpleadoLista.Count(e => !e.Activo) }
                            };
                        }
                        
                        <DxChart 
                        Data="@datosEmpleados"
                        Width="100%"
                        Height="350px">
                            <DxChartBarSeries
                             Name="Empleados"
                             ArgumentField="@((EmpleadoEstado e) => e.Estado)"
                             ValueField="@((EmpleadoEstado e) => e.Cantidad)"
                             Color="System.Drawing.Color.SteelBlue">
                                <DxChartSeriesLabel
                                 Visible="true"
                                 Position="RelativePosition.Outside">
                                    <DxChartSeriesLabelConnector Visible="true" />
                                </DxChartSeriesLabel>
                            </DxChartBarSeries>

                            <DxChartLegend 
                            Position="RelativePosition.Outside"
                            HorizontalAlignment="HorizontalAlignment.Center"
                            VerticalAlignment="VerticalEdge.Bottom" />
  
                            <DxChartTooltip
                            Enabled="true"/>
                        </DxChart>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0">Distribución por Tipo de Combustible (Tanques)</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosCombustible = TanqueLista
                                .Where(t => t.Activo)
                                .GroupBy(t => t.TipoCombustible ?? "Sin especificar")
                                .Select(g => new TanqueCombustible
                                {
                                    TipoCombustible = g.Key,
                                    Cantidad = g.Count(),
                                    CapacidadTotal = g.Sum(t => t.Capacidad ?? 0)
                                })
                                .ToList();
                        }
                        
                        @if (datosCombustible.Any())
                        {
                            <DxPieChart
                             Data="@datosCombustible"
                             Width="100%"
                             Height="350px"
                             InnerDiameter="0.5">
                                <DxPieChartSeries
                                 Name="Combustible"
                                 ArgumentField="@((TanqueCombustible t) => t.TipoCombustible)"
                                 ValueField="@((TanqueCombustible t) => t.CapacidadTotal)">
                                    <DxChartSeriesLabel
                                    Visible="true"
                                    Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxPieChartSeries>
                                
                              <DxChartLegend 
                                Position="RelativePosition.Outside"
                                HorizontalAlignment="HorizontalAlignment.Center"
                                VerticalAlignment="VerticalEdge.Bottom" />
    
                                <DxChartTooltip
                                Enabled="true"/>
                            </DxPieChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay tanques activos registrados</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-info text-white">
                        <h4 class="mb-0">Nivel de Combustible por Tanque</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosNiveles = TanqueLista
                                .Where(t => t.Activo)
                                .Select(t => new TanqueNivel
                                {
                                    Nombre = $"Tanque {t.Id} - {t.TipoCombustible}",
                                    Nivel = t.Nivel ?? 0,
                                    Capacidad = t.Capacidad ?? 0
                                })
                                .ToList();
                        }
                        
                        @if (datosNiveles.Any())
                        {
                            <DxChart
                             Data="@datosNiveles"
                             Width="100%"
                             Height="350px">
                                <DxChartBarSeries 
                                Name="Nivel Actual"
                                ArgumentField="@((TanqueNivel t) => t.Nombre)"
                                ValueField="@((TanqueNivel t) => t.Nivel)"
                                Color="System.Drawing.Color.Orange">
                                  <DxChartSeriesLabel
                                    Visible="true"
                                    Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                  </DxChartBarSeries>
                                
                                <DxChartBarSeries 
                                Name="Capacidad Máxima"
                                ArgumentField="@((TanqueNivel t) => t.Nombre)"
                                ValueField="@((TanqueNivel t) => t.Capacidad)"
                                Color="System.Drawing.Color.LightGray">
                                      <DxChartSeriesLabel
                                    Visible="true"
                                    Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartBarSeries>
                                
                                <DxChartLegend 
                                Position="RelativePosition.Outside"
                                HorizontalAlignment="HorizontalAlignment.Center"
                                VerticalAlignment="VerticalEdge.Bottom" />
    
                                <DxChartTooltip
                                Enabled="true"/>
                            </DxChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay tanques activos registrados</div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">Vehículos por Tipo de Combustible</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosVehiculosCombustible = VehiculoLista
                                .Where(v => v.Activo)
                                .GroupBy(v => v.TipoCombustible ?? "Sin especificar")
                                .Select(g => new VehiculoCombustible
                                {
                                    TipoCombustible = g.Key,
                                    Cantidad = g.Count()
                                })
                                .ToList();
                        }
                        
                        @if (datosVehiculosCombustible.Any())
                        {
                            <DxPieChart  
                                Data="@datosVehiculosCombustible"
                                Width="100%"
                                Height="350px">
                                    
                                <DxPieChartSeries   
                                Name="Vehículos por Combustible"
                                ArgumentField="@((VehiculoCombustible v) => v.TipoCombustible)"
                                ValueField="@((VehiculoCombustible v) => v.Cantidad)">
                                  <DxChartSeriesLabel
                                    Visible="true"
                                    Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxPieChartSeries>

                               <DxChartLegend 
                                Position="RelativePosition.Outside"
                                HorizontalAlignment="HorizontalAlignment.Center"
                                VerticalAlignment="VerticalEdge.Bottom" />
    
                                <DxChartTooltip
                                Enabled="true"/>
                            </DxPieChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay vehículos activos registrados</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-danger text-white">
                        <h4 class="mb-0">Estado de Vehículos</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosEstadoVehiculos = new List<VehiculoEstado>
                            {
                                new VehiculoEstado { Estado = "Activos", Cantidad = VehiculoLista.Count(v => v.Activo) },
                                new VehiculoEstado { Estado = "Inactivos", Cantidad = VehiculoLista.Count(v => !v.Activo) }
                            };
                        }
                        
                        @if (VehiculoLista.Any())
                        {
                            <DxChart 
                            Data="@datosEstadoVehiculos"
                            Width="100%"
                            Height="350px">
                                <DxChartTitle Text="Cantidad de Vehículos">
                                    <DxChartSubTitle Text="Vehículos activos e inactivos" />
                                </DxChartTitle>
                                <DxChartBarSeries 
                                Name="Vehículos"
                                ArgumentField="@((VehiculoEstado v) => v.Estado)"
                                ValueField="@((VehiculoEstado v) => v.Cantidad)"
                                Color="System.Drawing.Color.OrangeRed">
                                  <DxChartSeriesLabel
                                    Visible="true"
                                    Position="RelativePosition.Outside">
                                        <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartBarSeries>
                                    
                               <DxChartLegend 
                                Position="RelativePosition.Outside"
                                HorizontalAlignment="HorizontalAlignment.Center"
                                VerticalAlignment="VerticalEdge.Bottom" />
  
                                <DxChartTooltip
                                Enabled="true"/>
                            </DxChart>
                        }
                        else
                        {
                            <div class="alert alert-warning">No hay vehículos registrados</div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white">
                        <h4 class="mb-0">Vehículos</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var datosMarcas = VehiculoLista
                                .Where(v => v.Activo && !string.IsNullOrEmpty(v.Marca))
                                .GroupBy(v => v.Marca)
                                .Select(g => new VehiculoMarca
                                {
                                    Marca = g.Key,
                                    Cantidad = g.Count()
                                })
                                .OrderByDescending(m => m.Cantidad)
                                .Take(5)
                                .ToList();
                        }
                        
                        @if (datosMarcas.Any())
                        {
                            <DxChart 
                            Data="@datosMarcas"
                            Width="100%"
                            Height="350px">
                                <DxChartTitle Text="Marcas de Vehículos">
                                    <DxChartSubTitle Text="Cantidad de Vehículos por Marca" />
                                </DxChartTitle>
                                <DxChartBarSeries 
                                Name="Cantidad por Marca"
                                ArgumentField="@((VehiculoMarca m) => m.Marca)"
                                ValueField="@((VehiculoMarca m) => m.Cantidad)"
                                Color="System.Drawing.Color.Purple">
                                    <DxChartSeriesLabel
                                        Visible="true"
                                        Position="RelativePosition.Outside">
                                            <DxChartSeriesLabelConnector Visible="true" />
                                    </DxChartSeriesLabel>
                                </DxChartBarSeries>
                                
                                <DxChartLegend 
                                Position="RelativePosition.Outside"
                                HorizontalAlignment="HorizontalAlignment.Center"
                                VerticalAlignment="VerticalEdge.Bottom" />
  
                                <DxChartTooltip
                                Enabled="true"/>
                            </DxChart>
                        }
                        else
                        {
                            <div class="alert alert-info">No hay datos de marcas disponibles</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h4 class="mb-0">Lista Detallada de Vehículos</h4>
                    </div>
                    <div class="card-body">
                        @if (VehiculoLista.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>ID</th>
                                            <th>Marca</th>
                                            <th>Modelo</th>
                                            <th>Matrícula</th>
                                            <th>Tipo Combustible</th>
                                            <th>Empleado Asignado</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var vehiculo in VehiculoLista)
                                        {
                                            var empleado = EmpleadoLista.FirstOrDefault(e => e.Id == vehiculo.IdEmpleado);
                                            <tr>
                                                <td>@vehiculo.Id</td>
                                                <td>@vehiculo.Marca</td>
                                                <td>@vehiculo.Modelo</td>
                                                <td>@vehiculo.Matricula</td>
                                                <td>@vehiculo.TipoCombustible</td>
                                                <td>@(empleado?.Nombre ?? "No asignado")</td>
                                                <td class="@(vehiculo.Activo ? "text-success" : "text-danger")">
                                                    @(vehiculo.Activo ? "Activo" : "Inactivo")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">No hay vehículos registrados</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h4 class="mb-0">Resumen de Tanques</h4>
                    </div>
                    <div class="card-body">
                        @{
                            var resumenTanques = TanqueLista
                                .GroupBy(t => t.TipoCombustible ?? "Sin especificar")
                                .Select(g => new ResumenTanque
                                {
                                    TipoCombustible = g.Key,
                                    Cantidad = g.Count(),
                                    CapacidadTotal = g.Sum(t => t.Capacidad ?? 0),
                                    NivelPromedio = g.Average(t => t.Nivel ?? 0),
                                    Activos = g.Count(t => t.Activo),
                                    Inactivos = g.Count(t => !t.Activo)
                                })
                                .ToList();
                        }
                        
                        @if (resumenTanques.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Tipo de Combustible</th>
                                            <th>Tanques</th>
                                            <th>Capacidad Total (L)</th>
                                            <th>Nivel Promedio (L)</th>
                                            <th>Activos</th>
                                            <th>Inactivos</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in resumenTanques)
                                        {
                                            <tr>
                                                <td><strong>@item.TipoCombustible</strong></td>
                                                <td>@item.Cantidad</td>
                                                <td>@item.CapacidadTotal.ToString("N0")</td>
                                                <td>@item.NivelPromedio.ToString("N0")</td>
                                                <td class="text-success">@item.Activos</td>
                                                <td class="text-danger">@item.Inactivos</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card shadow-sm text-center">
                    <div class="card-body">
                        <h3>Empleados Activos</h3>
                        <h2 class="text-success display-4">@EmpleadoLista.Count(e => e.Activo)</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm text-center">
                    <div class="card-body">
                        <h3>Empleados Inactivos</h3>
                        <h2 class="text-danger display-4">@EmpleadoLista.Count(e => !e.Activo)</h2>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Empleado> EmpleadoLista = new();
    private List<Tanque> TanqueLista = new();
    private List<Vehiculo> VehiculoLista = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpleados();
        await CargarTanques();
        await CargarVehiculos();
    }

    private async Task CargarEmpleados()
    {
        try
        {
            EmpleadoLista = await Task.Run(() => EmpleadoService.GetEmpleados());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar empleados: {ex.Message}");
        }
    }

    private async Task CargarTanques()
    {
        try
        {
            TanqueLista = await Task.Run(() => TanqueService.GetTanques());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar tanques: {ex.Message}");
        }
    }

    private async Task CargarVehiculos()
    {
        try
        {
            VehiculoLista = await Task.Run(() => VehiculoService.GetVehiculos());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar vehículos: {ex.Message}");
        }
    }

    // Clases auxiliares
    public class EmpleadoEstado
    {
        public string? Estado { get; set; }
        public int Cantidad { get; set; }
    }

    public class TanqueCombustible
    {
        public string? TipoCombustible { get; set; }
        public int Cantidad { get; set; }
        public decimal CapacidadTotal { get; set; }
    }

    public class TanqueNivel
    {
        public string? Nombre { get; set; }
        public decimal Nivel { get; set; }
        public decimal Capacidad { get; set; }
    }

    public class VehiculoEstado
    {
        public string? Estado { get; set; }
        public int Cantidad { get; set; }
    }

    public class VehiculoCombustible
    {
        public string? TipoCombustible { get; set; }
        public int Cantidad { get; set; }
    }

    public class VehiculoMarca
    {
        public string? Marca { get; set; }
        public int Cantidad { get; set; }
    }

    public class ResumenTanque
    {
        public string? TipoCombustible { get; set; }
        public int Cantidad { get; set; }
        public decimal CapacidadTotal { get; set; }
        public decimal NivelPromedio { get; set; }
        public int Activos { get; set; }
        public int Inactivos { get; set; }
    }
}

