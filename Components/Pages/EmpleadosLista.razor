@page "/empleados"
@rendermode InteractiveServer
@using PistaCombustible.Models
@using PistaCombustible.Services
@using DevExpress.Blazor
@inject EmpleadoService EmpleadoService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Gestión de empleados</PageTitle>


<div style="width: 80%; margin: auto;">
    <div class="d-flex align-items-center mb-3">
        <h1 class="me-3 mb-0">Lista de empleados</h1>
        <DxButton RenderStyle="ButtonRenderStyle.Primary" Size="ButtonSize.Small" Click="() => AdicionarEmpleado()"
                  IconCssClass="bi bi-plus-circle" />
            
    </div>
   
    @if (EmpleadoLista == null)
    {
        <span>Cargando...</span>
    }
    else if (!EmpleadoLista.Any())
    {
        <div class="alert alert-warning">
            No hay empleados registrados.
        </div>
    }
    else
    {
        <DxGrid Data="EmpleadoLista" ShowFilterRow="true" AllowSort="true" AllowPaging="true" PageSize="10"
                ShowPageSizeSelector="true" PageSizes="new int[] { 5, 10, 20, 50 }" AllowGroup="true" CssClass="shadow-sm"
                ColumnCaptionAlignment="GridTextAlignment.Center" ShowSearchBox="true">
        
            <Columns>
                <DxGridDataColumn FieldName="Id" Caption="ID" SortOrder="GridColumnSortOrder.Ascending" />
            
                <DxGridDataColumn FieldName="NombreCompleto" Caption="Nombre Completo" />
            
                <DxGridDataColumn FieldName="Email" Caption="Correo Electrónico" />
            
                <DxGridDataColumn FieldName="FechaNacimiento" Caption="Fecha Nacimiento" DisplayFormat="dd/MM/yyyy">
                    <CellDisplayTemplate>
                        @{
                            var fecha = (DateTime?)context.Value;
                            @(fecha?.ToString("dd/MM/yyyy") ?? "N/A")
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            
                <DxGridDataColumn FieldName="Salario" Caption="Salario" DisplayFormat="c">
                    <FooterTemplate>
                        <strong class="colorTotal">Total: $@(EmpleadoLista.Sum(e => e.Salario) ?? 0)</strong>
                    </FooterTemplate>
                </DxGridDataColumn>
            
                <DxGridDataColumn FieldName="Activo" Caption="Estado">
                    <CellDisplayTemplate>
                        @if ((bool)context.Value)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="FechaCreacion" Caption="Fecha creación" />
            
                <DxGridDataColumn Caption="Acciones" Width="120px">
                    <CellDisplayTemplate>
                        @{
                            var empleado = (Empleado)context.DataItem;
                            <DxButton RenderStyle="ButtonRenderStyle.Danger" Size="ButtonSize.Small"
                                      Click="() => EliminarEmpleado(empleado.Id)" IconCssClass="bi bi-trash" />
                            <DxButton RenderStyle="ButtonRenderStyle.Primary" Size="ButtonSize.Small"
                                      Click="() => ActualizarEmpleado(empleado.Id)" IconCssClass="bi bi-pen" />
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
        <span class="totalEmpleado d-block mt-3">@EmpleadoLista.Count() empleados en total</span>
    }
</div>

@code {
    private List<Empleado> EmpleadoLista = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarEmpleados();
    }

    /// <summary>
    /// Carga empleados
    /// </summary>
    /// <returns></returns>
    private async Task CargarEmpleados()
    {
        try
        {
            EmpleadoLista = await Task.Run(() => EmpleadoService.GetEmpleados());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar empleados: {ex.Message}");
        }
    }

    /// <summary>
    /// Elimina empleado
    /// </summary>
    /// <param name="id"></param>
    /// <returns></returns>
    private async Task EliminarEmpleado(int id)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Está seguro de eliminar este empleado?");

        if (confirmado)
        {
            var success = await Task.Run(() => EmpleadoService.DeleteEmpleadoFisico(id));
            if (success)
            {
                await CargarEmpleados();
                await JS.InvokeVoidAsync("alert", "Empleado eliminado correctamente");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Error al eliminar el empleado");
            }
        }
    }

    /// <summary>
    /// Actualiza empleado
    /// </summary>
    /// <param name="id"></param>
    /// <returns></returns>
    private void ActualizarEmpleado(int id)
    {
        Navigation.NavigateTo($"/empleadoform/{id}");
    }

    /// <summary>
    /// Adiciona empleado
    /// </summary>
    private void AdicionarEmpleado()
    {
        Navigation.NavigateTo($"/empleadoform");
    }
}